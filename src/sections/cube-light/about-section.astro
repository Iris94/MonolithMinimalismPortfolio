---
import { SITE } from "../../constants";
---

<section class="about-section">
  <div class="about-columns">
    <div class="about-col--images">
      <div class="about-lines">
        <div class="about-line about-line--1"></div>
        <div class="about-line about-line--2"></div>
        <div class="about-line about-line--3"></div>
      </div>

      <div class="about-image-inner">
        <img src="/profile_r1_c1.jpg" class="profile-1" alt="Profile" />
        <img src="/profile_r1_c2.jpg" class="profile-2" alt="Profile" />
        <img src="/profile_r1_c3.jpg" class="profile-3" alt="Profile" />
      </div>
    </div>

    <div class="about-col--content">
      <div class="about-title">
        <h2><span class="about-black">About</span> <span class="about-accent">me</span></h2>
      </div>

      <div class="about-text">
        <div class="about-text-inner">
          <p class="about-paragraph">
            I am a developer with three years of experience split between fast-paced company environments and custom freelance projects. Fueled by a lifelong obsession with The Matrix, I look at software through a sharp, analytical lens.
          </p>
          <p class="about-paragraph">
            Rather than fighting the rise of AI, I embrace it pragmatically to build faster and smarter. I am the creator of the <strong>Monolith Minimalism</strong> design philosophy, translating raw architectural weight into digital interfaces. My latest release is <a href={SITE.QIKO} class="about-link" target="_blank" rel="noopener noreferrer">Qiko</a>, a decentralized P2P browser chat extension built for modern peer-to-peer communication.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-bottom: 10rem;
  }

  .about-columns {
    display: flex;
  }

  .about-col--images {
    flex: 0 0 35%;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .about-col--content {
    flex: 0 0 60%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 8rem;
  }

  .about-title {
    display: flex;
    justify-content: end;
    margin-top: 15%;
  }

  .about-title h2 {
    line-height: 1;
  }

  .about-black {
    color: var(--nord0);
  }

  .about-accent {
    color: var(--nord10);
  }

  .about-image-inner {
    display: flex;
    flex-direction: row;
    align-items: end;
    gap: 15px;
  }

  .profile-1,
  .profile-2,
  .profile-3 {
    width: 100%;
    height: 100%;
    max-height: 500px;
    object-fit: cover;
    display: block;
    box-shadow: 3px 3px 12px 0 rgba(0,0,0,0.35);
  }

  .about-lines {
    display: flex;
    flex-direction: row;
    justify-content: start;
    align-items: start;
    gap: calc(35% / 3 + 15px);
    padding-right: 1rem;
  }

  .about-line {
    width: 3px;
  }

  .about-line--1 {
    height: 300px;
    background: var(--nord0);
  }

  .about-line--2 {
    height: 450px;
    background: var(--nord0);
  }

  .about-line--3 {
    height: 700px;
    background: var(--nord10);
  }

  .about-text {
    display: flex;
    flex-direction: column;
  }

  .about-text-inner {
    flex: 1;
    padding-left: 4rem;
    padding-right: 1rem;
    text-align: right;
    display: flex;
    flex-direction: column;
    justify-content: end;
  }

  .about-paragraph {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    letter-spacing: 0.06em;
    color: var(--nord0);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .about-link {
    color: var(--nord10);
    text-decoration: underline;
    font-weight: 600;
    text-transform: uppercase;
  }

  .about-link:hover {
    color: var(--nord9);
  }
</style>
