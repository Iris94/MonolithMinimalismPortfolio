---
const aboutText =
  "I am currently working as a freelance software engineer specializing in Umbraco systems. Over the years, I've contributed to large-scale web applications for clients like Jesperhus, Maus and Inet. I have extensive experience collaborating with international companies, with a strong focus on the Scandinavian market.";
---

<section
  class="case"
  id="case"
>
  <div class="case-headings">
    <h2 class="case-case">CASE</h2>
    <h2 class="case-study">STUDY</h2>
  </div>
  <div class="case-content">
    <p class="case-paragraph">{aboutText}</p>
  </div>
</section>

<style>
  .case {
    position: relative;
    height: 85dvh;
    display: flex;
    flex-direction: row;
    justify-content: end;
    align-items: end;
    overflow: clip;
    color: var(--nord5);
  }

  .case-headings {
    position: absolute;
    top: 15%;
    left: 0;
    display: flex;
    flex-direction: column;
    pointer-events: none;
    z-index: 1;
  }

  .case-case {
    color: var(--nord5);
  }

  .case-study {
    color: var(--nord5);
  }

  .case-content {
    padding: 0 1rem 50px 0;
    max-width: 40%;
  }

  .case-paragraph {
    color: var(--nord5);
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    letter-spacing: 0.06em;
    margin: 0;
  }
</style>
