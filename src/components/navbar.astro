<nav>
  <ul class="nav-list">
    <li>
      <a href="#home" class="nav-link">
        <span>HOME</span>
        <span class="material-symbols-outlined nav-link-icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#about" class="nav-link">
        <span>ABOUT</span>
        <span class="material-symbols-outlined nav-link-icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#case" class="nav-link">
        <span>CASE STUDY</span>
        <span class="material-symbols-outlined nav-link-icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#" class="nav-link">
        <span>TECH STACK</span>
        <span class="material-symbols-outlined nav-link-icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#" class="nav-link">
        <span>CONTACT</span>
        <span class="material-symbols-outlined nav-link-icon">arrow_right_alt</span>
      </a>
    </li>
    <li class="nav-list__separator">
      <a href="#" class="nav-link nav-link--blog">
        <span>BLOG</span>
        <span class="material-symbols-outlined nav-link-icon">arrow_right_alt</span>
      </a>
    </li>
  </ul>
</nav>

<div class="sidenav-clock-wrapper">
  <div class="clock-ring">
    <svg class="clock-progress" viewBox="0 0 100 100">
      <circle
        class="clock-progress-circle"
        cx="50"
        cy="50"
        r="22"
        fill="none"
        stroke="white"
        stroke-width="44"
        stroke-linecap="butt"
        stroke-dasharray="138.23"
        stroke-dashoffset="138.23"
        transform="rotate(-90 50 50)"
      />
    </svg>
    <div class="clock-hand"></div>
  </div>
</div>

<style>
  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    list-style: none;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    color: white;
  }

  .nav-link:hover,
  .nav-link--active {
    font-weight: 700;
  }

  .nav-link-icon {
    font-size: 18px;
    font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
    color: white;
    transition: transform 0.2s;
  }

  .nav-link:hover .nav-link-icon {
    transform: translateX(4px);
  }

  .nav-list__separator {
    margin-top: auto;
  }

  .sidenav-clock-wrapper {
    display: flex;
    justify-content: center;
  }

  .clock-ring {
    width: 100%;
    aspect-ratio: 1;
    max-height: 100%;
    border-radius: 9999px;
    border: 1px solid white;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .clock-progress {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .clock-hand {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1.5px;
    height: 42%;
    background: white;
    transform-origin: top;
    transform: translateX(-50%) rotate(180deg);
    z-index: 2;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    let raf = null;
    function updateOnScroll() {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        raf = null;

        const darkCube = document.querySelector(".cube-master--dark");
        if (!darkCube) return;
        const rect = darkCube.getBoundingClientRect();
        const viewportH = window.innerHeight;
        const darkVisible = Math.max(0, Math.min(rect.bottom, viewportH) - Math.max(rect.top, 0));
        const darkRatio = Math.min(1, Math.max(0, darkVisible / viewportH));
        document.documentElement.setAttribute("data-fog-theme", darkRatio >= 0.95 ? "dark" : "light");

        const hand = document.querySelector(".clock-hand");
        const circle = document.querySelector(".clock-progress-circle");
        if (hand && circle) {
          const scrollY = window.scrollY;
          const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
          const progress = Math.min(1, Math.max(0, maxScroll > 0 ? scrollY / maxScroll : 0));
          hand.style.transform = `translateX(-50%) rotate(${180 + progress * 360}deg)`;
          const circumference = 2 * Math.PI * 22;
          circle.style.strokeDashoffset = circumference * (1 - progress);
        }
      });
    }

    window.addEventListener("scroll", updateOnScroll, { passive: true });
    window.addEventListener("resize", updateOnScroll);
    updateOnScroll();

    const sections = ["home", "about", "case"]
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    const linkMap = new Map();
    document.querySelectorAll(".nav-link").forEach((link) => {
      const href = link.getAttribute("href");
      if (href && href.startsWith("#")) {
        linkMap.set(href.slice(1), link);
      }
    });

    if (sections.length > 0) {
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const link = linkMap.get(entry.target.id);
            if (link) {
              link.classList.toggle("nav-link--active", entry.isIntersecting);
            }
          });
        },
        { rootMargin: "-40% 0px -40% 0px" }
      );
      sections.forEach((section) => sectionObserver.observe(section));
    }
  });
</script>
