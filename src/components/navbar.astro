---

<nav>
  <ul class="nav-list">
    <li>
      <a href="#" class="nav-link nav-link--active">
        <span>INDEX</span>
        <span class="material-symbols-outlined nav-link__icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#" class="nav-link">
        <span>STRUCTURE</span>
        <span class="material-symbols-outlined nav-link__icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#" class="nav-link">
        <span>ATMOSPHERE</span>
        <span class="material-symbols-outlined nav-link__icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#" class="nav-link">
        <span>CHRONICLE</span>
        <span class="material-symbols-outlined nav-link__icon">arrow_right_alt</span>
      </a>
    </li>
    <li>
      <a href="#" class="nav-link">
        <span>CONTACT</span>
        <span class="material-symbols-outlined nav-link__icon">arrow_right_alt</span>
      </a>
    </li>
  </ul>
</nav>

<div class="sidenav__clock-wrapper">
  <div class="clock-ring">
    <svg class="clock-progress" viewBox="0 0 100 100">
      <circle class="clock-progress__circle" cx="50" cy="50" r="22"
              fill="none" stroke="var(--nord0)"
              stroke-width="44" stroke-linecap="butt"
              stroke-dasharray="138.23" stroke-dashoffset="138.23"
              transform="rotate(-90 50 50)" />
    </svg>
    <div class="clock-hand"></div>
  </div>
</div>

<style>
  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    list-style: none;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    color: var(--nord3);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--nord0);
  }

  .nav-link--active {
    color: var(--nord0);
  }

  .nav-link__icon {
    font-size: 18px;
    font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
    transition: transform 0.2s;
  }

  .nav-link:hover .nav-link__icon {
    transform: translateX(4px);
  }

  .sidenav__clock-wrapper {
    display: flex;
    justify-content: center;
  }

  .clock-ring {
    width: 100%;
    aspect-ratio: 1;
    max-height: 100%;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--nord3) 20%, transparent);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .clock-progress {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .clock-hand {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1.5px;
    height: 42%;
    background: var(--nord0);
    transform-origin: top;
    transform: translateX(-50%) rotate(180deg);
    z-index: 2;
  }
</style>

<script>
  import { scroll, animate } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const hand = document.querySelector(".clock-hand");
    const circle = document.querySelector(".clock-progress__circle");

    if (!hand || !circle) return;

    const circumference = 2 * Math.PI * 22;

    scroll(
      animate(hand, {
        rotate: [180, 540]
      }),
      { axis: "y" }
    );

    scroll(
      animate(circle, {
        strokeDashoffset: [circumference, 0]
      }),
      { axis: "y" }
    );
  });
</script>
